generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id         String     @id
  username   String     @unique
  branchName String
  state      String
  password   String
  role       String     @default("ADMIN")
  createdAt  DateTime   @default(now())
  createdBy  String
  Purchase   Purchase[]
}

model Customer {
  id             String           @id
  name           String
  username       String           @unique
  password       String
  phone          String
  createdAt      DateTime         @default(now())
  mpin           String?
  coupons        Coupon[]
  CustomerScheme CustomerScheme[]
}

model CustomerScheme {
  id               String           @id
  customerId       String
  schemeId         String
  totalPaid        Float            @default(0)
  remainingAmount  Float
  installmentsPaid Int              @default(0)
  installmentsLeft Int
  isCompleted      Boolean          @default(false)
  startDate        DateTime         @default(now())
  accumulatedGrams Float            @default(0)
  coupon           Coupon?
  Customer         Customer         @relation(fields: [customerId], references: [id])
  Scheme           Scheme           @relation(fields: [schemeId], references: [id])
  PaymentHistory   PaymentHistory[]
}

model GoldJobWork {
  id                String    @id
  companyName       String
  productType       String
  goldGivenType     String
  goldGivenGrams    Float
  makingCharge      Float?
  status            String    @default("PENDING")
  dateGiven         DateTime
  dateReceived      DateTime?
  wastageGrams      Float?
  returnedGoldGrams Float?
  notes             String?
  createdBy         String
  createdAt         DateTime  @default(now())
}

model GoldPurchase {
  id            String   @id
  companyName   String
  goldType      String
  grams         Float
  pricePerGram  Float
  totalAmount   Float
  purchaseDate  DateTime
  invoiceNumber String?
  paymentMode   String?
  notes         String?
  createdBy     String
  createdAt     DateTime @default(now())
}

model OtpVerification {
  id            String    @id
  phoneNumber   String    @db.VarChar(15)
  otpCode       String    @db.VarChar(6)
  purpose       String    @db.VarChar(50)
  requestedById String?
  attempts      Int       @default(0)
  isUsed        Boolean   @default(false)
  expiresAt     DateTime
  verifiedAt    DateTime?
  createdAt     DateTime  @default(now())

  @@index([phoneNumber])
  @@index([phoneNumber, purpose])
  @@index([purpose])
}

model Product {
  id              String         @id
  name            String
  metalType       String
  carats          String
  category        String         @default("others")
  bodyPart        String         @default("others")
  grams           Float
  stoneWeight     Float          @default(0)
  netWeight       Float          @default(0)
  quantity        Int            @default(1)
  huid            String?
  uniqueCode      String         @unique
  sku             String         @unique
  isSold          Boolean        @default(false)
  manufactureDate DateTime
  createdAt       DateTime       @default(now())
  soldAt          DateTime?
  branchName      String         @default("Gajuwaka")
  va              Float          @default(2.5)
  stoneCost       Float          @default(0)
  PurchaseItem    PurchaseItem[]
}

model ProductImgs {
  id          String   @id
  title       String
  description String?
  weight      Float
  image       Bytes
  mimeType    String   @default("image/jpeg")
  metalType   String   @default("gold")
  carats      String   @default("24k")
  createdAt   DateTime @default(now())
}

model Purchase {
  id                        String         @id
  customerName              String
  emailid                   String?
  Address                   String?
  totalAmount               Float
  discountAmount            Float
  finalAmount               Float
  phoneNumber               String
  paymentId                 String?        @default("MANUAL_POS")
  paymentStatus             String         @default("SUCCESS")
  purchasedAt               DateTime       @default(now())
  adminId                   String?
  superAdminId              String?
  cgstAmount                Float          @default(0)
  sgstAmount                Float          @default(0)
  excahngejewellrygrams     Float?
  excahngejewellryname      String?
  jewelleryexchangediscount Float?
  cardAmount                Float          @default(0)
  cashAmount                Float          @default(0)
  chequeAmount              Float          @default(0)
  upiAmount                 Float          @default(0)
  invoice                   String         @default("svj-234")
  Admin                     Admin?         @relation(fields: [adminId], references: [id])
  SuperAdmin                SuperAdmin?    @relation(fields: [superAdminId], references: [id])
  PurchaseItem              PurchaseItem[]
}

model PurchaseItem {
  id         String   @id
  purchaseId String
  productId  String
  name       String
  grams      Float
  cost       Float
  isReturned Boolean  @default(false)
  Product    Product  @relation(fields: [productId], references: [id])
  Purchase   Purchase @relation(fields: [purchaseId], references: [id])
}

model Scheme {
  id             String           @id
  name           String
  durationMonths Int
  monthlyAmount  Float
  createdAt      DateTime         @default(now())
  isWeightBased  Boolean          @default(false)
  maturityMonths Int?
  coupons        Coupon[]
  CustomerScheme CustomerScheme[]
}

model Staff {
  id            String   @id
  fullName      String
  dateOfJoining DateTime
  monthlySalary Float
  gender        String
  phoneNumber   String   @unique
  aadharNumber  String   @unique
  createdAt     DateTime @default(now())
  createdBy     String
}

model SuperAdmin {
  id        String     @id
  username  String     @unique
  password  String
  createdAt DateTime   @default(now())
  Purchase  Purchase[]
}

model Coupon {
  id               String          @id
  code             String          @unique
  isUsed           Boolean         @default(false)
  usedAt           DateTime?
  createdAt        DateTime        @default(now())
  customerSchemeId String?         @unique
  customerId       String
  schemeId         String?
  isActive         Boolean         @default(true)
  totalCashValue   Float           @default(0)
  totalWeightGrams Float           @default(0)
  description      String?
  type             String          @default("WEIGHT")
  value            Float           @default(0)
  Customer         Customer        @relation(fields: [customerId], references: [id])
  CustomerScheme   CustomerScheme? @relation(fields: [customerSchemeId], references: [id])
  Scheme           Scheme?         @relation(fields: [schemeId], references: [id])
}

model PaymentHistory {
  id               String         @id
  customerSchemeId String
  amountPaid       Float
  liveRate24K      Float?
  gramsAdded       Float?
  paidAt           DateTime       @default(now())
  CustomerScheme   CustomerScheme @relation(fields: [customerSchemeId], references: [id])
}

model CreditNote {
  id           String       @id
  productName  String
  grams        Float
  carats       String?
  stoneWeight  Float?
  overallCost  Float
  couponId     String
  createdAt    DateTime     @default(now())
  ReturnCoupon ReturnCoupon @relation(fields: [couponId], references: [id])
}

model ReturnCoupon {
  id         String       @id
  code       String       @unique
  cashAmount Float
  isUsed     Boolean      @default(false)
  createdAt  DateTime     @default(now())
  invoice    String       @default("#svn")
  CreditNote CreditNote[]
}
